<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ChahriyaPro.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ChahriyaPro.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Chahriya Pro">

    <!-- 
        Fichier : AppShell.xaml
        Emplacement : Racine du projet
        Description : Définit la structure de navigation de l'application (barre d'onglets, menu latéral).
    -->

    <!-- Barre d'onglets principale (Tabbar) -->
    <TabBar>
        <Tab Title="Accueil" Icon="home_icon.png">
            <ShellContent
                Title="Accueil"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab Title="Historique" Icon="history_icon.png">
            <ShellContent
                Title="Historique"
                ContentTemplate="{DataTemplate local:HistoryPage}"
                Route="HistoryPage" />
        </Tab>
    </TabBar>

</Shell>
