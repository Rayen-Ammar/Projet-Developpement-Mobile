<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:ChahriyaPro.ViewModels"
             xmlns:models="clr-namespace:ChahriyaPro.Models"
             x:DataType="viewmodel:MainViewModel"
             x:Class="ChahriyaPro.Views.HistoryPage"
             Title="Historique"
             BackgroundColor="{StaticResource Background}">

    <CollectionView ItemsSource="{Binding MonthlyHistory}" 
                    IsGrouped="True" 
                    Margin="20">
        
        <!-- Header for each month group -->
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate x:DataType="viewmodel:MonthlyHistoryGroup">
                <VerticalStackLayout Spacing="5" Padding="0,10,0,10">
                    <Label Text="{Binding MonthName}" 
                           Style="{StaticResource SubtitleLabel}" 
                           TextColor="{StaticResource Primary}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Label Grid.Column="0" 
                               Text="{Binding FormattedMonthlyIncome}" 
                               TextColor="{StaticResource Success}" 
                               FontSize="12" 
                               FontFamily="OpenSansSemibold" />
                        <Label Grid.Column="1" 
                               Text="{Binding FormattedMonthlyExpenses}" 
                               TextColor="{StaticResource Danger}" 
                               FontSize="12" 
                               FontFamily="OpenSansSemibold" 
                               HorizontalOptions="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,5,0,0" />
                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <!-- Item template for transactions -->
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Transaction">
                <Frame Style="{StaticResource CardFrame}" Padding="15" Margin="0,5,0,5" BorderColor="{StaticResource Gray200}">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                        <BoxView Grid.Column="0" WidthRequest="4" Color="{Binding AmountColor}" CornerRadius="2" VerticalOptions="Fill" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="{Binding Description}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" 
                               Text="{Binding FormattedAmount}" 
                               TextColor="{Binding AmountColor}" 
                               FontSize="15" 
                               FontFamily="OpenSansSemibold" 
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="50">
                <Label Text="Aucun historique disponible" 
                       TextColor="{StaticResource TextSecondary}" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </CollectionView.EmptyView>
    </CollectionView>
</ContentPage>
